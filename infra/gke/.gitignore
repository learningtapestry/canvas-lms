# Terraform
.terraform/
*.tfstate
*.tfstate.*
tfplan
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
# Keep .terraform.lock.hcl committed (provider pinning)
!.terraform.lock.hcl

# Secret-bearing tfvars must never be committed — pass secrets via TF_VAR_*.
# (the committed terraform.tfvars holds non-secret config only)
*.auto.tfvars
*.auto.tfvars.json
secrets.tfvars
*.secret.tfvars
