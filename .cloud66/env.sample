ENCRYPTION_KEY=AUTO_GENERATE_128
JWT_ENCRYPTION_KEY=AUTO_GENERATE_64
CANVAS_DOMAIN=canvas.example.com
RAILS_ENV=production
RACK_ENV=production
NODE_ENV=production

# Required for the first deploy against a fresh Canvas database.
CANVAS_LMS_ADMIN_EMAIL=admin@example.com

# Optional, but strongly recommended for production file uploads.
FILE_STORAGE_PATH_PREFIX=storage/files
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Optional outgoing mail.
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_DOMAIN=example.com
SMTP_OUTGOING_ADDRESS=canvas@example.com
SMTP_DEFAULT_NAME=Canvas
